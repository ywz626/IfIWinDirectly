# ============================================================
# Godot 4 (C# / Mono)
# ============================================================
# Godot 构建缓存与中间产物，由编辑器自动生成
.godot/

# 平台导出目录（如需提交模板请单独处理）
/android/
/ios/

# 导出签名、证书、密码等凭据：永远不要提交
export_credentials.cfg

# Godot 3.x 残留缓存
.import/

# ============================================================
# .NET / C#
# ============================================================
# 编译产物
bin/
obj/

# IDE 用户设置（不可共享）
*.user
*.suo
*.userprefs
*.sln.DotSettings.user

# Visual Studio 本地缓存
.vs/

# 调试符号与崩溃日志
*.pdb
mono_crash.*
*.log

# NuGet 包缓存
packages/
*.nupkg

# ============================================================
# JetBrains Rider / IntelliJ / Visual Studio Code
# 一律忽略 IDE 个人配置，开源仓库不放 IDE 文件
# ============================================================
.idea/
.vscode/

# ============================================================
# 开发过程中的本地草稿与设计文档
# 单独保留在本地，不进入仓库
# ============================================================
docs/superpowers/

# ============================================================
# 操作系统生成文件
# ============================================================
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ============================================================
# 编辑器临时文件
# ============================================================
*.swp
*.swo
*~
*.bak
*.orig

# ============================================================
# 环境变量与本地秘钥
# ============================================================
.env
.env.local
.env.*.local
*.pem
*.key
